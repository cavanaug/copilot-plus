#!/usr/bin/env bash
set -euo pipefail

VERSION="0.8.20260304"

GLOBAL_SETTINGS="${HOME}/.copilot/settings.json"
LEGACY_GLOBAL_CONFIG="${HOME}/.copilot/config.json"

# Strip JSONC comments (// line comments, /* block comments */) and trailing
# commas so standard jq can parse the result.
# Requires: hjson (brew install hjson)
# Usage: strip_jsonc <file>   — emits clean JSON on stdout
strip_jsonc() {
    hjson -c "$1"
}

read_normalized_config() {
    local config_file="$1"
    local normalized_json

    if ! normalized_json="$(strip_jsonc "$config_file" 2>/dev/null)"; then
        echo "copilot-plus: error: invalid JSON/JSONC in $config_file" >&2
        return 2
    fi

    if ! jq empty <<<"$normalized_json" 2>/dev/null; then
        echo "copilot-plus: error: invalid JSON/JSONC in $config_file" >&2
        return 2
    fi

    printf '%s\n' "$normalized_json"
}

read_settings_policy() {
    local settings_file="$1"
    local normalized_json
    local status
    local root_type
    local policy_type

    [[ -f "$settings_file" ]] && [[ -r "$settings_file" ]] || return 1

    normalized_json="$(read_normalized_config "$settings_file")" || {
        status=$?
        return "$status"
    }

    root_type="$(jq -r 'type' <<<"$normalized_json")"
    if [[ "$root_type" != "object" ]]; then
        echo "copilot-plus: error: expected object root in $settings_file" >&2
        return 2
    fi

    if [[ "$(jq -r 'has("copilotPlus")' <<<"$normalized_json")" != "true" ]]; then
        return 1
    fi

    policy_type="$(jq -r '.copilotPlus | type' <<<"$normalized_json")"
    if [[ "$policy_type" != "object" ]]; then
        echo "copilot-plus: error: expected object at key 'copilotPlus' in $settings_file" >&2
        return 2
    fi

    jq -c '.copilotPlus' <<<"$normalized_json"
}

read_legacy_policy() {
    local config_file="$1"
    local normalized_json
    local status
    local root_type
    local policy_key_count

    [[ -f "$config_file" ]] && [[ -r "$config_file" ]] || return 1

    normalized_json="$(read_normalized_config "$config_file")" || {
        status=$?
        return "$status"
    }

    root_type="$(jq -r 'type' <<<"$normalized_json")"
    if [[ "$root_type" != "object" ]]; then
        echo "copilot-plus: error: expected object root in $config_file" >&2
        return 2
    fi

    policy_key_count="$(jq -r '[keys[] | select(test("^\\s*--"))] | length' <<<"$normalized_json")"
    if [[ "$policy_key_count" == "0" ]]; then
        return 1
    fi

    jq -c 'with_entries(select(.key | test("^\\s*--"))) | with_entries(.key |= sub("^\\s+"; ""))' <<<"$normalized_json"
}

# Walk upward from $PWD to find the nearest project with wrapper policy host files.
# Stops at the first matching directory, or at a .git/ boundary (project root), or at /.
# Also stops at HOME boundary to prevent global ~/.copilot files from being treated as project config.
# Sets PROJECT_* candidate paths; PROJECT_ROOT is only assigned later if wrapper policy is actually present.
find_project_policy_candidates() {
    local dir="$PWD"
    while true; do
        local shared_settings="$dir/.github/copilot/settings.json"
        local local_settings="$dir/.github/copilot/settings.local.json"
        local legacy_config="$dir/.copilot/config.json"

        if [[ -f "$shared_settings" ]] || [[ -f "$local_settings" ]] || [[ -f "$legacy_config" ]]; then
            PROJECT_ROOT_CANDIDATE="$dir"
            PROJECT_SHARED_SETTINGS="$shared_settings"
            PROJECT_LOCAL_SETTINGS="$local_settings"
            LEGACY_PROJECT_CONFIG="$legacy_config"
            return
        fi

        if [[ -d "$dir/.git" ]]; then
            PROJECT_ROOT_CANDIDATE=""
            PROJECT_SHARED_SETTINGS=""
            PROJECT_LOCAL_SETTINGS=""
            LEGACY_PROJECT_CONFIG=""
            return
        fi

        local parent
        parent="$(dirname "$dir")"
        if [[ "$parent" == "$HOME" ]] || [[ "$dir" == "$HOME" ]]; then
            PROJECT_ROOT_CANDIDATE=""
            PROJECT_SHARED_SETTINGS=""
            PROJECT_LOCAL_SETTINGS=""
            LEGACY_PROJECT_CONFIG=""
            return
        fi

        if [[ "$parent" == "$dir" ]]; then
            PROJECT_ROOT_CANDIDATE=""
            PROJECT_SHARED_SETTINGS=""
            PROJECT_LOCAL_SETTINGS=""
            LEGACY_PROJECT_CONFIG=""
            return
        fi

        dir="$parent"
    done
}

collect_non_array_keys() {
    local policy_json="$1"
    local -n _keys_ref="$2"

    [[ -n "$policy_json" ]] || return 0

    while IFS= read -r key; do
        _keys_ref["$key"]=1
    done < <(jq -r 'to_entries[] | select(.key | startswith("--")) | select(.value | type != "array") | .key' <<<"$policy_json")
}

check_policy_type_conflicts() {
    local policy_json="$1"
    local policy_source="$2"
    local -n _types_ref="$3"
    local -n _sources_ref="$4"

    [[ -n "$policy_json" ]] || return 0

    while IFS=$'\t' read -r key vtype; do
        local normalized_type="scalar"
        if [[ "$vtype" == "array" ]]; then
            normalized_type="array"
        fi

        if [[ -v _types_ref["$key"] ]] && [[ "${_types_ref["$key"]}" != "$normalized_type" ]]; then
            echo "copilot-plus: error: type conflict for key '$key': '${_types_ref["$key"]}' in ${_sources_ref["$key"]}, '$normalized_type' in $policy_source" >&2
            exit 1
        fi

        _types_ref["$key"]="$normalized_type"
        _sources_ref["$key"]="$policy_source"
    done < <(jq -r 'to_entries[] | select(.key | startswith("--")) | [.key, (.value | type)] | @tsv' <<<"$policy_json")
}

# Read all -- flags from a policy object into a named array (by reference).
# Usage: read_policy_flags <policy_json> <source_name> <array_ref> <skip_keys_assoc_array_ref>
read_policy_flags() {
    local policy_json="$1"
    local policy_source="$2"
    local -n _flags_ref="$3"
    local -n _skip_ref="$4"

    [[ -n "$policy_json" ]] || return 0

    while IFS= read -r key; do
        if [[ -v _skip_ref["$key"] ]]; then
            continue
        fi

        local vtype
        vtype=$(jq -r --arg k "$key" '.[$k] | type' <<<"$policy_json")

        case "$vtype" in
        array)
            while IFS= read -r element; do
                local expanded
                expanded="$(envsubst <<<"$element")"
                if [[ "$key" == "--add-dir" ]] && [[ ! -d "$expanded" ]]; then
                    continue
                fi
                _flags_ref+=("$key" "$expanded")
            done < <(jq -r --arg k "$key" '.[$k][]' <<<"$policy_json")
            ;;
        boolean)
            local val
            val=$(jq -r --arg k "$key" '.[$k]' <<<"$policy_json")
            if [[ "$val" == "true" ]]; then
                _flags_ref+=("$key")
            fi
            ;;
        string | number)
            local val
            val=$(jq -r --arg k "$key" '.[$k]' <<<"$policy_json")
            local expanded
            expanded="$(envsubst <<<"$val")"
            if [[ "$key" == "--add-dir" ]] && [[ ! -d "$expanded" ]]; then
                :
            else
                _flags_ref+=("$key" "$expanded")
            fi
            ;;
        object | null | *)
            echo "copilot-plus: error: unsupported value type '$vtype' for key '$key' in $policy_source" >&2
            exit 1
            ;;
        esac
    done < <(jq -r 'keys[] | select(startswith("--"))' <<<"$policy_json")
}

GLOBAL_POLICY_JSON=""
GLOBAL_POLICY_SOURCE=""
if GLOBAL_POLICY_JSON="$(read_settings_policy "$GLOBAL_SETTINGS")"; then
    GLOBAL_POLICY_SOURCE="$GLOBAL_SETTINGS"
else
    status=$?
    if [[ "$status" -gt 1 ]]; then
        exit 1
    fi

    if GLOBAL_POLICY_JSON="$(read_legacy_policy "$LEGACY_GLOBAL_CONFIG")"; then
        GLOBAL_POLICY_SOURCE="$LEGACY_GLOBAL_CONFIG"
    else
        status=$?
        if [[ "$status" -gt 1 ]]; then
            exit 1
        fi
        GLOBAL_POLICY_JSON=""
    fi
fi

PROJECT_ROOT_CANDIDATE=""
PROJECT_SHARED_SETTINGS=""
PROJECT_LOCAL_SETTINGS=""
LEGACY_PROJECT_CONFIG=""
find_project_policy_candidates

PROJECT_ROOT=""
PROJECT_POLICY_JSON=""
PROJECT_POLICY_SOURCE=""
PROJECT_LOCAL_POLICY_JSON=""
PROJECT_LOCAL_POLICY_SOURCE=""

if [[ -n "$PROJECT_ROOT_CANDIDATE" ]]; then
    if PROJECT_POLICY_JSON="$(read_settings_policy "$PROJECT_SHARED_SETTINGS")"; then
        PROJECT_POLICY_SOURCE="$PROJECT_SHARED_SETTINGS"
    else
        status=$?
        if [[ "$status" -gt 1 ]]; then
            exit 1
        fi
        PROJECT_POLICY_JSON=""
    fi

    if PROJECT_LOCAL_POLICY_JSON="$(read_settings_policy "$PROJECT_LOCAL_SETTINGS")"; then
        PROJECT_LOCAL_POLICY_SOURCE="$PROJECT_LOCAL_SETTINGS"
    else
        status=$?
        if [[ "$status" -gt 1 ]]; then
            exit 1
        fi
        PROJECT_LOCAL_POLICY_JSON=""
    fi

    if [[ -n "$PROJECT_POLICY_JSON" ]] || [[ -n "$PROJECT_LOCAL_POLICY_JSON" ]]; then
        PROJECT_ROOT="$PROJECT_ROOT_CANDIDATE"
    elif PROJECT_POLICY_JSON="$(read_legacy_policy "$LEGACY_PROJECT_CONFIG")"; then
        PROJECT_POLICY_SOURCE="$LEGACY_PROJECT_CONFIG"
        PROJECT_ROOT="$PROJECT_ROOT_CANDIDATE"
    else
        status=$?
        if [[ "$status" -gt 1 ]]; then
            exit 1
        fi
        PROJECT_POLICY_JSON=""
    fi
fi

# Build combined flags: global (minus overridden keys) + project
config_flags=()
declare -A no_skip=()
declare -A project_skip=()
declare -A global_skip=()
declare -A policy_key_types=()
declare -A policy_key_sources=()

check_policy_type_conflicts "$GLOBAL_POLICY_JSON" "$GLOBAL_POLICY_SOURCE" policy_key_types policy_key_sources
check_policy_type_conflicts "$PROJECT_POLICY_JSON" "$PROJECT_POLICY_SOURCE" policy_key_types policy_key_sources
check_policy_type_conflicts "$PROJECT_LOCAL_POLICY_JSON" "$PROJECT_LOCAL_POLICY_SOURCE" policy_key_types policy_key_sources

collect_non_array_keys "$PROJECT_POLICY_JSON" global_skip
collect_non_array_keys "$PROJECT_LOCAL_POLICY_JSON" global_skip
collect_non_array_keys "$PROJECT_LOCAL_POLICY_JSON" project_skip

read_policy_flags "$GLOBAL_POLICY_JSON" "$GLOBAL_POLICY_SOURCE" config_flags global_skip
read_policy_flags "$PROJECT_POLICY_JSON" "$PROJECT_POLICY_SOURCE" config_flags project_skip
read_policy_flags "$PROJECT_LOCAL_POLICY_JSON" "$PROJECT_LOCAL_POLICY_SOURCE" config_flags no_skip

# Auto-inject project root as --add-dir if a .copilot/ was found via upward search (only if dir exists)
if [[ -n "$PROJECT_ROOT" ]] && [[ -d "$PROJECT_ROOT" ]]; then
    config_flags+=("--add-dir" "$PROJECT_ROOT")
fi

# Export COPILOT_ARGS: shell-quoted, space-separated config-injected flags only (not user args)
# This allows nested calls: copilot $COPILOT_ARGS <new-args>
if [[ ${#config_flags[@]} -eq 0 ]]; then
    COPILOT_ARGS=""
else
    COPILOT_ARGS=$(printf '%q ' "${config_flags[@]}")
    COPILOT_ARGS="${COPILOT_ARGS% }" # trim trailing space
fi
export COPILOT_ARGS

# Parse ++ / + options from user args; strip them before passing to copilot
do_cmd=0
do_env=0
do_verbose=0
do_help=0
do_version=0
user_args=()
for arg in "$@"; do
    case "$arg" in
    ++cmd) do_cmd=1 ;;
    ++env) do_env=1 ;;
    ++verbose | +v) do_verbose=1 ;;
    ++help | +h) do_help=1 ;;
    ++version | +V) do_version=1 ;;
    *) user_args+=("$arg") ;;
    esac
done

# ++help / +h (check first so it works even with bad args)
if [[ "$do_help" -eq 1 ]]; then
    printf 'copilot-plus options:\n'
    printf '  ++cmd           print the command that would be run, then exit\n'
    printf '  ++env           print COPILOT_ARGS value, then exit\n'
    printf '  ++verbose, +v   print command and COPILOT_ARGS, then run normally\n'
    printf '  ++help,    +h   show this help\n'
    printf '  ++version, +V   print version and exit\n'
    printf '\n'
    printf '  --xxx, -x       all other params passed to copilot\n'
    exit 0
fi

# ++version / +V
if [[ "$do_version" -eq 1 ]]; then
    printf 'copilot-plus %s\n' "$VERSION"
    exit 0
fi

# Shared helper: print the command that would be run
# --flags are printed bare; value arguments are double-quoted (inner " escaped as \")
print_cmd() {
    local cmd=(copilot "${config_flags[@]+"${config_flags[@]}"}" "${user_args[@]+"${user_args[@]}"}")
    printf '%s' "${cmd[0]}"
    for part in "${cmd[@]:1}"; do
        if [[ "$part" == --* ]]; then
            printf ' %s' "$part"
        else
            printf ' "%s"' "${part//\"/\\\"}"
        fi
    done
    printf '\n'
}

# ++cmd: print command and exit
if [[ "$do_cmd" -eq 1 ]]; then
    print_cmd
    exit 0
fi

# ++env: print COPILOT_ARGS and exit
if [[ "$do_env" -eq 1 ]]; then
    printf '%s\n' "$COPILOT_ARGS"
    exit 0
fi

# ++verbose / +v: print diagnostics, then fall through to exec (intentionally no exit)
if [[ "$do_verbose" -eq 1 ]]; then
    printf '[copilot-plus] cmd: '
    print_cmd
    printf '[copilot-plus] env: COPILOT_ARGS=%s\n' "$COPILOT_ARGS"
    # intentionally no exit — falls through to exec below
fi

exec copilot "${config_flags[@]+"${config_flags[@]}"}" "${user_args[@]+"${user_args[@]}"}"
